# Neon Database (Non-Pooling URL recommended for serverless)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx

# Email (Gmail SMTP)
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM_NAME=Your Store Name

# WhatsApp (CallMeBot - free, no Twilio needed)
# Register at https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_API_KEY=your_callmebot_apikey
ADMIN_WHATSAPP=919999999999

# Facebook Pixel
NEXT_PUBLIC_FB_PIXEL_ID=your_pixel_id

# JWT Secret (for user sessions)
JWT_SECRET=your_random_jwt_secret_minimum_32_chars

# Admin JWT Secret (generate random 64 char string)
ADMIN_JWT_SECRET=your_super_secret_admin_jwt_key_minimum_64_chars

# Site URL
NEXT_PUBLIC_BASE_URL=https://yoursite.vercel.app

# Store Info
NEXT_PUBLIC_STORE_NAME=Digital Store
NEXT_PUBLIC_STORE_TAGLINE=Premium Digital Products
